# App
NEXT_PUBLIC_APP_NAME=どぅいっとなう
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Legacy JWT keys:
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Or newer publishable/secret keys (either pair works):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...

# Resend
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=どぅいっとなう <noreply@your-verified-domain.com>

# External links
NEXT_PUBLIC_SETROUNDLY_URL=https://setroundly.com
NEXT_PUBLIC_DEFAULT_DONATE_URL=https://setroundly.com/donate
